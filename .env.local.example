# Supabase — 從 Supabase Dashboard > Project Settings > API 取得
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 僅 server-side 使用，切勿暴露於前端
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 簽發學員自簽 JWT（= Supabase Dashboard > Project Settings > API > JWT Settings > JWT Secret）
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Web Push（VAPID）— 用 `npx web-push generate-vapid-keys` 產生
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
